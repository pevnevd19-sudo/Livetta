server {
    listen 80;
    server_name livettajew.ru www.livettajew.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name livettajew.ru www.livettajew.ru;

    # Пути к сертификатам добавляются панелью хостинга или Certbot.
    ssl_certificate /etc/letsencrypt/live/livettajew.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/livettajew.ru/privkey.pem;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
